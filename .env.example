# Copy to .env for local dev. Never commit real values.

# Required
MONGODB_URI="mongodb+srv://USER:PASS@cluster.example.mongodb.net/?appName=YourApp"
JWT_SECRET="generate-with-openssl-rand-base64-32"
INTERNAL_S2S_SECRET="generate-with-openssl-rand-base64-32"
COMMS_SHARED_SECRET="generate-with-openssl-rand-base64-32"
COMMS_URL="http://localhost:8081"
COMPANIES_SERVICE_URL="http://localhost:8082"
WORKSPACES_SERVICE_URL="http://localhost:8083"
PORTAL_PUBLIC_URL="http://localhost:3000"

# Optional — when unset, falls back to console-log adapter (dev only)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# Dev OTP shortcut — enable only in non-production
DEV_OTP_BYPASS=""
DEV_OTP_BYPASS_CODE=""
DEV_OTP_PEEK=""

BCRYPT_ROUNDS="10"
PORT="8080"
LOG_LEVEL="info"
